{
  // engine/ and daemon/ are excluded from the Cargo workspace so `cargo build-sbf` never
  // tries to build the host-only crates for the BPF target. These linkedProjects let
  // rust-analyzer load them (and their examples) anyway.
  "rust-analyzer.linkedProjects": [
    "./Cargo.toml",
    "./engine/Cargo.toml",
    "./daemon/Cargo.toml"
  ]
}
